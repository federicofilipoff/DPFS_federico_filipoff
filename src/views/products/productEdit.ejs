<!DOCTYPE html>
<html lang="es">

<%- include('../partials/head', { title: 'Editar producto',
stylesheets: ['/css/styles.css', '/css/form.css'] }) %>

    <%- include('../partials/header') %>
    
    <main>

        <form action="/product/<%= producto.id %>?_method=PUT" method="POST">
            <h2>Editar producto</h2>
            <input type="text" name="productName" id="productName" value="<%= producto.productName %>" placeholder="Nombre del producto" required>
            <input type="text" name="productDescription" id="productDescription" value="<%= producto.productDescription %>" placeholder="Descripción del producto" required>
            <input type="file" name="image" id="image" value="<%= producto.image %>" accept="image/*" required>
            <input type="text" name="category" id="category" value="<%= producto.category %>" placeholder="Categoría del producto" required>
            <input type="text" name="colors" id="colors" value="<%= producto.colors %>" placeholder="Color del producto" required>
            <input type="text" name="size" id="size" value="<%= producto.size %>" placeholder="Dimensiones/tamaño" required>
            <input type="number" name="productPrice" id="productPrice" value="<%= producto.productPrice %>" placeholder="Precio" min="1" required>
            <hr>
            <button type="submit">Guardar Producto</button>
        </form>

    </main>

    <%- include('../partials/footer') %>

</html>